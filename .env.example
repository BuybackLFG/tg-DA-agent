# Redis
REDIS_URL=redis://redis:6379/0

# Sandbox
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# App
LOG_LEVEL=INFO
